{
  "name": "codeaptor-api",
  "version": "1.0.0",
  "description": "Codeaptor Managed DevOps & Hosting Infrastructure API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "docker:build": "docker build -t codeaptor-api .",
    "docker:run": "docker run -p 3000:3000 --env-file .env codeaptor-api"
  },
  "keywords": [],
  "author": "Codeaptor",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "bullmq": "^5.77.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.6.2",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "socket.io": "^4.8.3",
    "telegraf": "^4.16.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
